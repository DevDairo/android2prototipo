<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="20dp"
    android:background="#121212">

    <androidx.cardview.widget.CardView
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_marginTop="30dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp">
        <ImageView
            android:id="@+id/imgPortada"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/portada1" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="25dp"
        android:paddingStart="10dp">
        <TextView
            android:id="@+id/txtNombreCancion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="we can't be friends"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/txtArtista"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ariana Grande"
            android:textColor="#B3B3B3"
            android:textSize="16sp" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/seekBarTiempo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:progressTint="#1DB954"
        android:thumbTint="#1DB954" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginTop="15dp">

        <Button
            android:id="@+id/btnRetroceder"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="-10"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnAnterior"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="⏮"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btnPlayPause"
            android:layout_width="100dp"
            android:layout_height="60dp"
            android:backgroundTint="#FFFFFF"
            android:text="▶"
            android:textColor="#000000"
            android:textSize="15sp"
            app:cornerRadius="35dp" />

        <Button
            android:id="@+id/btnSiguiente"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="⏭"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btnAdelantar"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="+10"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/seekBarVolumen"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:progressTint="#B3B3B3"
        android:thumbTint="#FFFFFF" />

</LinearLayout>